<Page x:Class="ServiceDesk.Frames.AddEditEmployeeFrame"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ServiceDesk.Frames"
      mc:Ignorable="d" 
      d:DesignHeight="540" d:DesignWidth="690"
      Title="AddEditEmployeeFrame">
    <Page.Resources>
        
    </Page.Resources>   

    <Grid>
        <Border CornerRadius="10" Background="{StaticResource fon}">

            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="5*"/>
                    <RowDefinition Height="40"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" >
                    <StackPanel Orientation="Vertical">
                        <WrapPanel Orientation="Horizontal" VerticalAlignment="Top">
                            <Label Style="{StaticResource addTaskLabels}" Content="ФИО" Margin="0 5 0 0"/>
                            <Label Content="*" Margin="0" Foreground="{StaticResource accentColor}"/>
                        </WrapPanel>
                        <Border HorizontalAlignment="Left" Width="400"  Style="{StaticResource createFrameBorderTextBox}" >
                            <TextBox x:Name="fioEmployeeTextBox" Style="{StaticResource transparentTextBox}" Background="White" />
                        </Border>
                    </StackPanel>

                    <WrapPanel VerticalAlignment="Center" Margin="10 10 0 0" x:Name="inactiveEmployeeBox">
                        <Label Style="{StaticResource addTaskLabels}" Content="Недействителен: " Margin="0 5 0 0"/>
                        <CheckBox x:Name="inactiveEmployee" Template="{DynamicResource CheckBoxTemplate}" VerticalAlignment="Bottom" Margin="5 0 0 7" Style="{StaticResource checkBoxAddData}" />
                    </WrapPanel>
                </StackPanel>

                <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0 0 10 0" >
                    <WrapPanel>
                        <Label Style="{StaticResource addTaskLabels}" Content="Департамент" />
                        <Label Content="*" Margin="0" Foreground="{StaticResource accentColor}"/>
                    </WrapPanel>

                    <Border CornerRadius="10" Background="White"  Height="30" HorizontalAlignment="Stretch">
                        <ComboBox x:Name="departmentComboBox" Style="{StaticResource comboBoxSort}" Height="30"  Width="auto" Margin="0" />
                    </Border>

                    <WrapPanel Margin="0 10 0 0">
                        <Label Style="{StaticResource addTaskLabels}" Content="Должность" />
                        <Label Content="*" Margin="0" Foreground="{StaticResource accentColor}"/>
                    </WrapPanel>

                    <Border CornerRadius="10" Background="White"  Height="30" HorizontalAlignment="Stretch">
                        <ComboBox x:Name="postComboBox" Style="{StaticResource comboBoxSort}" Height="30"  Width="auto" Margin="0" />
                    </Border>

                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal" Margin="0 40 0 0">
                        <Label  Style="{StaticResource addTaskLabels}" Content="Разрешен вход в приложение:"/>
                        <CheckBox x:Name="allowLogin" Template="{DynamicResource CheckBoxTemplate}" VerticalAlignment="Bottom" Margin="5 0 0 7" Style="{StaticResource checkBoxAddData}" Click="allowLogin_Click" />
                    </StackPanel>

                    <Grid x:Name="loginPasswordPanel">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Vertical" Margin="0 0 5 0">
                            <Label Style="{StaticResource addTaskLabels}" HorizontalAlignment="Stretch" Content="Логин" Margin="0 10 0 0"/>

                            <Border Style="{StaticResource createFrameBorderTextBox}" >
                                <TextBox x:Name="loginTextBox" Style="{StaticResource transparentTextBox}" Background="White" />
                            </Border>

                            <Label Style="{StaticResource addTaskLabels}" Content="Пароль" Margin="0 10 0 0"/>

                            <Border  Style="{StaticResource createFrameBorderTextBox}" Padding="0">
                                <PasswordBox x:Name="passwordTextBox" Style="{StaticResource passwordInputText}" Template="{StaticResource PasswordBoxTemplate1}" Width="140" HorizontalAlignment="Left" Background="White" Height="22" />
                            </Border>
                        </StackPanel>

                        <WrapPanel Orientation="Vertical" Margin="5 0 0 0" Grid.Column="1" HorizontalAlignment="Stretch">
                            <Label Style="{StaticResource addTaskLabels}" Content="Роль" Margin="0 10 0 0"/>

                            <ComboBox x:Name="roleComboBox" Style="{StaticResource comboBoxSort}" Width="155" Height="30" Margin="0" />
                        </WrapPanel>

                    </Grid>
                    
                        
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Vertical" Margin="10 0 0 0" >
                    <Label Style="{StaticResource addTaskLabels}" Content="Почта" />

                    <Border Style="{StaticResource createFrameBorderTextBox}">
                        <TextBox x:Name="emailTextBox" Style="{StaticResource transparentTextBox}" Background="White" />
                    </Border>

                    <Label Style="{StaticResource addTaskLabels}" Content="Телефон" Margin="0 10 0 0"/>

                    <Border Style="{StaticResource createFrameBorderTextBox}">
                        <TextBox x:Name="phoneTextBox" Style="{StaticResource transparentTextBox}" Background="White" />
                    </Border>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"   Background="Transparent"  Grid.Row="2" Grid.Column="1" >
                    
                    <Button x:Name="goToEmployeeListButton" Height="30" Width="86" Margin="0 0 10 0" Background="White" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" Style="{StaticResource buttonsWithText}" Template="{StaticResource whiteButtons}" Click="goToEmployeeListButton_Click" >
                        <Border CornerRadius="10" HorizontalAlignment="Stretch"  >
                            <TextBlock Text="Назад" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource darkGreenMenu}"/>
                        </Border>
                    </Button>

                    <Button x:Name="createEmployeeButton" Height="30" Width="125" Background="White" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" Style="{StaticResource buttonsWithText}" Template="{StaticResource whiteButtons}" Click="createEmployeeButton_Click" >
                        <Border CornerRadius="10" HorizontalAlignment="Stretch"  >
                            <TextBlock x:Name="createTaskButtonTextBlock"  Text="Создать" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource darkGreenMenu}"/>
                        </Border>
                    </Button>
                    
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
