<Page x:Class="ServiceDesk.Frames.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ServiceDesk.Frames"
      mc:Ignorable="d" 
      d:DesignHeight="610" d:DesignWidth="900"
      Title="LoginPage">
    <Page.Resources>
        
    </Page.Resources>

    <Border Style="{StaticResource mainBorder}">
        <Border.Background>
            <ImageBrush ImageSource="\Images\back.jpg"/>
        </Border.Background>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource startBorder}">
                <Border.Background>
                    <SolidColorBrush Color="White" Opacity="0.82"/>
                </Border.Background>

                <StackPanel VerticalAlignment="Center" Margin="40 0" HorizontalAlignment="Center" Width="250">
                    <Label HorizontalAlignment="Center" Foreground="{StaticResource darkGreenMenu}" Content="Авторизация" Margin="0 0 0 20" FontSize="22" FontFamily="Montserrat Medium"/>

                    <Border BorderBrush="#7c854a" BorderThickness="0 0 0 2">
                        <WrapPanel Margin="0 0 0 5">
                            <Image Source="\Images\Icons\controlButtons\user.png" Height="25"/>
                            <TextBox x:Name="loginTextBox" Template="{DynamicResource textBoxLogin}" Style="{StaticResource loginInputText}"  Margin="10 0 0 0"/>
                        </WrapPanel>
                    </Border>

                    <Border Margin="0 30 0 20" BorderBrush="#7c854a" BorderThickness="0 0 0 2">
                        <WrapPanel Margin="0 0 0 5">
                            <Image Source="\Images\Icons\controlButtons\password.png" Height="25"/>
                            <PasswordBox x:Name="passwordTextBox" Template="{DynamicResource PasswordBoxTemplate1}" Style="{StaticResource passwordInputText}" Margin="10 0 0 0" />
                        </WrapPanel>
                    </Border>

                    <Button x:Name="checkLoginData" Template="{DynamicResource buttonLoginTemplate}" Style="{StaticResource buttonLogin}" Content="Войти" Click="goToStart_Click" Opacity="1"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Column="1">
                <Label Content="ServiceDesk" Foreground="{StaticResource darkGreenMenu}" FontSize="40" FontFamily="Montserrat ExtraLight" HorizontalAlignment="Center" Margin="0 60 0 0"/>
            </StackPanel>
            
        </Grid>
        
    </Border>
</Page>
