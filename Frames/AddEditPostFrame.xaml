<Page x:Class="ServiceDesk.Frames.AddEditPostFrame"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ServiceDesk.Frames"
      mc:Ignorable="d" 
      d:DesignHeight="540" d:DesignWidth="690"
      Title="AddEditPostFrame">

    <Grid>
        <Grid Background="{StaticResource fon}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>

            <WrapPanel Orientation="Vertical" Margin="10">
                <Label Content="Наименование" Margin="0"/>
                <Border Style="{StaticResource createFrameBorderTextBox}" Width="200" Margin="0 5 0 0">
                    <TextBox x:Name="titlePost" Style="{StaticResource transparentTextBox}" Template="{DynamicResource textBoxLogin}" />
                </Border>
            </WrapPanel>

            <StackPanel Orientation="Horizontal" Margin="0 0 10 10" HorizontalAlignment="Right" Background="Transparent"  Grid.Row="2" Grid.Column="1" >

                <Button x:Name="goToPostsListButton" Height="30" Width="86" Margin="0 0 10 0" Background="White" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" Style="{StaticResource buttonsWithText}" Template="{StaticResource whiteButtons}" Click="goToPostsListButton_Click" >
                    <Border CornerRadius="10" HorizontalAlignment="Stretch"  >
                        <TextBlock Text="Назад" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource darkGreenMenu}"/>
                    </Border>
                </Button>

                <Button x:Name="createPostButton" Height="30" Width="125" Background="White" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" Style="{StaticResource buttonsWithText}" Template="{StaticResource whiteButtons}" Click="createPostButton_Click"  >
                    <Border CornerRadius="10" HorizontalAlignment="Stretch"  >
                        <TextBlock x:Name="createPostButtonTextBlock"  Text="Создать" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource darkGreenMenu}"/>
                    </Border>
                </Button>

            </StackPanel>
        </Grid>
    </Grid>
</Page>
