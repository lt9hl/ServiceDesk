<Page x:Class="ServiceDesk.Frames.TaskHistoryFrame"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ServiceDesk.Frames"
      mc:Ignorable="d" 
           d:DesignHeight="540" d:DesignWidth="690"
      Title="TasksFrame">

    <Grid Background="Transparent">
        <Border  CornerRadius="10">
            <Border.Background>
                <SolidColorBrush Color="#f2f2ed" />
            </Border.Background>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition Height="40"/>
                </Grid.RowDefinitions>

                <StackPanel VerticalAlignment="Bottom" Grid.Row="1"  Margin="10 0 0 10">
                    <Button x:Name="goToTask" Background="White" HorizontalAlignment="Left" VerticalAlignment="Bottom" Height="30" Width="100" Margin="0 10 0 0" Style="{StaticResource buttonsWithText}" Template="{StaticResource whiteButtons}" Click="goToTask_Click">
                        <Border CornerRadius="10" HorizontalAlignment="Stretch"  >
                            <TextBlock Text="Назад" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource darkGreenMenu}"/>
                        </Border>
                    </Button>
                </StackPanel>
                
                <Grid Background="Transparent" Grid.Row="0">
                    <Border Margin="10 10 10 15" CornerRadius=" 10">
                        <Border.Background>
                            <SolidColorBrush Color="White" />
                        </Border.Background>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource columnRowTable}" CornerRadius="10 0 0 0">
                                <Label Content="Дата изменения" Margin="2 0 0 0" Style="{StaticResource tasksTableLabel}"/>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource columnRowTable}" BorderThickness="0 1 1 1">
                                <Label Content="Статус" Style="{StaticResource tasksTableLabel}"/>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource columnRowTable}" BorderThickness="0 1 1 1"  CornerRadius="0 10 0 0">
                                <Label Content="Заголовок" Style="{StaticResource tasksTableLabel}"/>
                            </Border>

                            <ListView d:ItemsSource="{d:SampleData}" ScrollViewer.HorizontalScrollBarVisibility="Hidden"  ItemContainerStyle="{StaticResource itemsListViewTable}" Margin="0" Grid.Row="2" Grid.ColumnSpan="5" BorderBrush="Transparent" x:Name="listViewTasks" MouseDoubleClick="listViewTasks_MouseDoubleClick"  >
                                <ListView.ItemTemplate >
                                    <DataTemplate >
                                        <Grid  >
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="188"/>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Visibility="Collapsed" Margin="0 0 5 0" Style="{StaticResource tableData}">
                                                <TextBlock x:Name="idTaskHistoryTextBox" Padding="0 0 5 0" TextWrapping="NoWrap">
                                                    <Run Text="{Binding idTaskHistory}"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <StackPanel Grid.Column="0" Margin="0 0 5 0" Style="{StaticResource tableData}">
                                                <TextBlock Padding="0 0 5 0" TextWrapping="NoWrap" TextTrimming="WordEllipsis">
                                                    <Run Text="{Binding createDate}" />
                                                </TextBlock>
                                            </StackPanel>

                                            <StackPanel Margin="9 0 0 0" VerticalAlignment="Center" Grid.Column="1" Style="{StaticResource tableData}" HorizontalAlignment="Center" >
                                                <Image Source="{Binding TaskStatuses.imageStatus}" Height="20" HorizontalAlignment="Center"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" Style="{StaticResource tableData}" Margin="10 0 0 0">
                                                <TextBlock TextWrapping="NoWrap" TextTrimming="WordEllipsis">
                                                    <Run Text="{Binding title}"/>
                                                </TextBlock>
                                            </StackPanel>

                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <Border Grid.Row="1" Grid.Column="0" BorderBrush="{StaticResource staticControlColor}" BorderThickness="1 0 1 1" CornerRadius="0 0 0 10"/>
                            <Border Grid.Row="1" Grid.Column="1" BorderBrush="{StaticResource staticControlColor}" BorderThickness="0 0 1 1" />
                            <Border Grid.Row="1" Grid.Column="2" BorderBrush="{StaticResource staticControlColor}" BorderThickness="0 0 1 1" CornerRadius="0 0 10 0"/>

                        </Grid>
                    </Border>
                </Grid>
                
            </Grid>
        </Border>
    </Grid>
</Page>
