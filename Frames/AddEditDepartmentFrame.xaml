<Page x:Class="ServiceDesk.Frames.AddEditDepartmentFrame"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ServiceDesk.Frames"
      mc:Ignorable="d" 
      d:DesignHeight="540" d:DesignWidth="690"
      Title="AddEditDepartmentFrame">

    <Grid Background="{StaticResource fon}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <WrapPanel Orientation="Vertical" Margin="10">
            <Label Content="Наименование" Margin="0"/>
            <Border Style="{StaticResource createFrameBorderTextBox}" Width="200" Margin="0 5 0 0">
                <TextBox x:Name="titleDepartment" Style="{StaticResource transparentTextBox}" Template="{DynamicResource textBoxLogin}" />
            </Border>
        </WrapPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 0 10 10" Background="Transparent"  Grid.Row="2" Grid.Column="1" >

            <Button x:Name="goToDepartmentListButton" Height="30" Width="86" Margin="0 0 10 0" Background="White" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" Style="{StaticResource buttonsWithText}" Template="{StaticResource whiteButtons}" Click="goToDepartmentListButton_Click" >
                <Border CornerRadius="10" HorizontalAlignment="Stretch"  >
                    <TextBlock Text="Назад" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource darkGreenMenu}"/>
                </Border>
            </Button>

            <Button x:Name="createDepartmentButton" Height="30"  Width="125" Background="White" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" Style="{StaticResource buttonsWithText}" Template="{StaticResource whiteButtons}" Click="createDepartmentButton_Click"  >
                <Border CornerRadius="10" HorizontalAlignment="Stretch"  >
                    <TextBlock x:Name="createDepartmentButtonTextBlock"  Text="Создать" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource darkGreenMenu}"/>
                </Border>
            </Button>

        </StackPanel>
    </Grid>
</Page>
